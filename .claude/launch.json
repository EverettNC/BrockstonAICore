{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js (Turbopack)",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "PATH=/usr/local/bin:$PATH npm run dev"],
      "port": 9002
    },
    {
      "name": "Genkit Dev UI",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "PATH=/usr/local/bin:$PATH npm run genkit:dev"],
      "port": 4000
    },
    {
      "name": "Genkit Dev UI (watch)",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "PATH=/usr/local/bin:$PATH npm run genkit:watch"],
      "port": 4000
    }
  ]
}
