# ==============================================================================
# BROCKSTON .env.example
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.
# ==============================================================================

# ── AI Providers ──────────────────────────────────────────────────────────────
# Anthropic (fallback if Ollama is unavailable)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Generative AI (Genkit)
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here

# ── Ollama (local sovereign model — primary AI backbone) ──────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3

# ── AWS (Polly TTS) ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# ── Memory & Storage ─────────────────────────────────────────────────────────
MEMORY_FILE_PATH=./memory/memory_store.json

# ── Avatar ────────────────────────────────────────────────────────────────────
# Set to false to run headless (no avatar engine)
BROCKSTON_ENABLE_AVATAR=true

# ── OpenSmell ─────────────────────────────────────────────────────────────────
# Telemetry port for ambient sensing integration (default: 5050)
OPENSMELL_TELEMETRY_PORT=5050
# Severity threshold 1 (all) to 5 (critical only) — default 3
OPENSMELL_ALERT_SEVERITY_THRESHOLD=3

# ── Next.js App ───────────────────────────────────────────────────────────────
# Port for the Next.js dev server (matches package.json)
PORT=9002
