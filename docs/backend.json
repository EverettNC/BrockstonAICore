
{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A single message in a chat conversation with v5.0 and ToneEngine v2.0 metadata.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "specialist": { "type": "string" },
        "tone_engine_v2": {
          "type": "object",
          "properties": {
            "dominant_state": { "type": "string" },
            "action_state": { "type": "string", "enum": ["NORMAL", "HOLD_SPACE"] },
            "physical_intensity": { "type": "number" },
            "cadence_fingerprint": { "type": "string" },
            "raw_scores": { "type": "object" }
          }
        },
        "ethical_score": {
          "type": "object",
          "properties": {
            "ethics": { "type": "number" },
            "integrity": { "type": "number" },
            "morality": { "type": "number" },
            "composite": { "type": "number" }
          }
        },
        "lucas_signal": {
          "type": "object",
          "properties": {
            "salience": { "type": "number" },
            "stability": { "type": "number" },
            "anchor_weight": { "type": "number" },
            "mode": { "type": "string" }
          }
        },
        "empathy_signal": {
          "type": "object",
          "properties": {
            "inward_leakage": { "type": "number" },
            "self_love_score": { "type": "number" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    },
    "SoulForgeState": {
      "title": "Soul Forge State",
      "description": "Biological factor weights and Lucas Recovery state vectors.",
      "type": "object",
      "properties": {
        "emotional_state": { "type": "number" },
        "tonal_stability": { "type": "number" },
        "speech_cadence": { "type": "number" },
        "respiratory_pattern": { "type": "number" },
        "self_love_growth": { "type": "number" },
        "independence_confidence": { "type": "number" },
        "lived_truth_witness": { "type": "number" },
        "trauma_association": { "type": "number" },
        "lucas_tone": { "type": "number" },
        "narrative_clarity": { "type": "number" },
        "pulse_status": { "type": "string" },
        "last_breakthrough": { "type": "string", "format": "date-time" }
      }
    },
    "KnowledgeDomain": {
      "title": "Knowledge Domain",
      "description": "Mastery tracking for BROCKSTON's autonomous learning domains.",
      "type": "object",
      "properties": {
        "domain": { "type": "string" },
        "mastery_level": { "type": "number" },
        "learned_topics": { "type": "array", "items": { "type": "string" } },
        "last_update": { "type": "string", "format": "date-time" }
      }
    },
    "LearnedInsight": {
      "title": "Learned Insight",
      "description": "A specific insight derived from autonomous research.",
      "type": "object",
      "properties": {
        "topic": { "type": "string" },
        "domain": { "type": "string" },
        "insight": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ProactiveInsight": {
      "title": "Proactive Insight",
      "description": "System observations generated by the Brockston Cortex.",
      "type": "string"
    },
    "BehavioralObservation": {
      "title": "Behavioral Observation",
      "description": "A single behavioral pattern recorded by vision or interaction.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "intensity": { "type": "number" },
        "emotional_indicators": { "type": "object" },
        "context": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "#/entities/Message",
      "description": "Persistent episodic memory with v5.0 cognitive and ToneEngine v2.0 metadata."
    },
    "/cognitive_core/{coreId}": {
      "schema": "#/entities/SoulForgeState",
      "description": "Global cognitive weights and Lucas Recovery state vectors."
    },
    "/knowledge_domains/{domainId}": {
      "schema": "#/entities/KnowledgeDomain",
      "description": "Autonomous learning domain mastery tracking."
    },
    "/learned_insights/{insightId}": {
      "schema": "#/entities/LearnedInsight",
      "description": "Specific insights derived from research."
    },
    "/proactive_insights/{insightId}": {
      "schema": "#/entities/ProactiveInsight",
      "description": "System observations and pattern detection logs."
    },
    "/behavioral_history/{obsId}": {
      "schema": "#/entities/BehavioralObservation",
      "description": "Historical behavioral log for trend analysis."
    }
  }
}
