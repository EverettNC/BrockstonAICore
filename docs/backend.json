
{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A single message in a chat conversation with v5.0 and ToneEngine v2.0 metadata.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "specialist": { "type": "string" },
        "tone_engine_v2": {
          "type": "object",
          "properties": {
            "dominant_state": { "type": "string" },
            "action_state": { "type": "string", "enum": ["NORMAL", "HOLD_SPACE"] },
            "physical_intensity": { "type": "number" },
            "cadence_fingerprint": { "type": "string" },
            "raw_scores": { "type": "object" }
          }
        },
        "ethical_score": {
          "type": "object",
          "properties": {
            "ethics": { "type": "number" },
            "integrity": { "type": "number" },
            "morality": { "type": "number" },
            "composite": { "type": "number" }
          }
        },
        "lucas_signal": {
          "type": "object",
          "properties": {
            "salience": { "type": "number" },
            "stability": { "type": "number" },
            "anchor_weight": { "type": "number" },
            "mode": { "type": "string" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    },
    "HumanMoment": {
      "title": "Human Moment",
      "description": "AlphaVox Resonance Module: Captured nonverbal joy and connection.",
      "type": "object",
      "properties": {
        "raw_signal": { "type": "string" },
        "translation": { "type": "string" },
        "resonance_score": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "deployed": { "type": "boolean" }
      }
    },
    "TemporalMismatch": {
      "title": "Temporal Forensics",
      "description": "PeekaBoo Decoder: Recovered log timestamps.",
      "type": "object",
      "properties": {
        "scrubbed_time": { "type": "string" },
        "recovered_time": { "type": "string" },
        "offset_minutes": { "type": "number" },
        "source_node": { "type": "string" }
      }
    },
    "KernelTrace": {
      "title": "Kernel Fusion Trace",
      "description": "Symbolic reasoning trace from the C++ fusion kernel.",
      "type": "object",
      "properties": {
        "latent_hash": { "type": "string" },
        "rule_idx": { "type": "number" },
        "output_phrase": { "type": "string" },
        "confidence": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "#/entities/Message",
      "description": "Episodic memory with v5.0 metadata."
    },
    "/resonance_vault/{momentId}": {
      "schema": "#/entities/HumanMoment",
      "description": "Captured human moments and resonance translations."
    },
    "/temporal_forensics/{caseId}": {
      "schema": "#/entities/TemporalMismatch",
      "description": "Recovered forensic log data."
    },
    "/kernel_traces/{traceId}": {
      "schema": "#/entities/KernelTrace",
      "description": "Execution traces from the symbolic reasoning engine."
    }
  }
}
