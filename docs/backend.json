
{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A single message in a chat conversation with full v5.0 metadata.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "specialist": { "type": "string" },
        "ethical_score": {
          "type": "object",
          "properties": {
            "ethics": { "type": "number" },
            "integrity": { "type": "number" },
            "morality": { "type": "number" },
            "composite": { "type": "number" }
          }
        },
        "lucas_signal": {
          "type": "object",
          "properties": {
            "salience": { "type": "number" },
            "stability": { "type": "number" },
            "anchor_weight": { "type": "number" },
            "mode": { "type": "string" }
          }
        },
        "empathy_signal": {
          "type": "object",
          "properties": {
            "inward_leakage": { "type": "number" },
            "self_love_score": { "type": "number" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    },
    "SoulForgeState": {
      "title": "Soul Forge State",
      "description": "Biological factor weights for adaptive learning.",
      "type": "object",
      "properties": {
        "emotional_state": { "type": "number" },
        "tonal_stability": { "type": "number" },
        "speech_cadence": { "type": "number" },
        "respiratory_pattern": { "type": "number" },
        "self_love_growth": { "type": "number" },
        "pulse_status": { "type": "string" },
        "last_breakthrough": { "type": "string", "format": "date-time" }
      }
    },
    "PulseBreakthrough": {
      "title": "Pulse Breakthrough",
      "description": "A record of a self-actualization loop being broken.",
      "type": "object",
      "properties": {
        "real_voice": { "type": "string" },
        "score_at_break": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "#/entities/Message",
      "description": "Persistent episodic memory with v5.0 cognitive metadata."
    },
    "/cognitive_core/{coreId}": {
      "schema": "#/entities/SoulForgeState",
      "description": "Global cognitive weights and biological bridge state."
    },
    "/pulse_breakthroughs/{breakthroughId}": {
      "schema": "#/entities/PulseBreakthrough",
      "description": "Records of broken self-actualization loops."
    }
  }
}
