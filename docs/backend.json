
{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A single message in a chat conversation with v5.0 and ToneEngine v2.0 metadata.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "specialist": { "type": "string" },
        "tone_engine_v2": {
          "type": "object",
          "properties": {
            "dominant_state": { "type": "string" },
            "action_state": { "type": "string", "enum": ["NORMAL", "HOLD_SPACE", "INTERVENTION"] },
            "physical_intensity": { "type": "number" },
            "cadence_fingerprint": { "type": "string" },
            "raw_scores": { "type": "object" }
          }
        },
        "ethical_score": {
          "type": "object",
          "properties": {
            "ethics": { "type": "number" },
            "integrity": { "type": "number" },
            "morality": { "type": "number" },
            "composite": { "type": "number" }
          }
        },
        "lucas_signal": {
          "type": "object",
          "properties": {
            "salience": { "type": "number" },
            "stability": { "type": "number" },
            "anchor_weight": { "type": "number" },
            "mode": { "type": "string" }
          }
        },
        "vortex_data": {
          "type": "object",
          "properties": {
            "intent_id": { "type": "string" },
            "confidence": { "type": "number" },
            "routing_mode": { "type": "string" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    },
    "VortexIntention": {
      "title": "Vortex Intention",
      "description": "A recorded predictive intention for system manifestation.",
      "type": "object",
      "properties": {
        "statement": { "type": "string" },
        "confidence": { "type": "number" },
        "manifested": { "type": "boolean" },
        "manifest_timestamp": { "type": "string", "format": "date-time" },
        "latency_seconds": { "type": "number" },
        "proof": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "HumanMoment": {
      "title": "Human Moment",
      "description": "AlphaVox Resonance Module: Captured nonverbal joy and connection.",
      "type": "object",
      "properties": {
        "raw_signal": { "type": "string" },
        "translation": { "type": "string" },
        "resonance_score": { "type": "number" },
        "infrastructure_insight": { "type": "string" },
        "deployment_log": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" },
        "mission_status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "#/entities/Message",
      "description": "Episodic memory with v5.0 and Cortex v2.0 metadata."
    },
    "/vortex_intentions/{intentId}": {
      "schema": "#/entities/VortexIntention",
      "description": "Predictive intention tracking for vortex quantification."
    },
    "/resonance_vault/{momentId}": {
      "schema": "#/entities/HumanMoment",
      "description": "Captured human moments and resonance translations."
    }
  }
}
