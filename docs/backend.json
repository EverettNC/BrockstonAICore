
{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A single message in a chat conversation with v5.0 and ToneEngine v2.0 metadata.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "specialist": { "type": "string" },
        "tone_engine_v2": {
          "type": "object",
          "properties": {
            "dominant_state": { "type": "string" },
            "action_state": { "type": "string", "enum": ["NORMAL", "HOLD_SPACE"] },
            "physical_intensity": { "type": "number" },
            "cadence_fingerprint": { "type": "string" },
            "raw_scores": { "type": "object" }
          }
        },
        "ethical_score": {
          "type": "object",
          "properties": {
            "ethics": { "type": "number" },
            "integrity": { "type": "number" },
            "morality": { "type": "number" },
            "composite": { "type": "number" }
          }
        },
        "lucas_signal": {
          "type": "object",
          "properties": {
            "salience": { "type": "number" },
            "stability": { "type": "number" },
            "anchor_weight": { "type": "number" },
            "mode": { "type": "string" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    },
    "HumanMoment": {
      "title": "Human Moment",
      "description": "AlphaVox Resonance Module: Captured nonverbal joy and connection.",
      "type": "object",
      "properties": {
        "raw_signal": { "type": "string" },
        "translation": { "type": "string" },
        "resonance_score": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "deployed": { "type": "boolean" }
      }
    },
    "ResonanceOverflow": {
      "title": "Resonance Overflow",
      "description": "Limit Break data from the Resonance Capacitor.",
      "type": "object",
      "properties": {
        "agony_input": { "type": "number" },
        "purpose_input": { "type": "number" },
        "total_load": { "type": "number" },
        "strength_multiplier": { "type": "number" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "#/entities/Message",
      "description": "Episodic memory with v5.0 metadata."
    },
    "/resonance_vault/{momentId}": {
      "schema": "#/entities/HumanMoment",
      "description": "Captured human moments and resonance translations."
    },
    "/resonance_overflows/{overflowId}": {
      "schema": "#/entities/ResonanceOverflow",
      "description": "Captured emotional limit breaks and strength surges."
    }
  }
}
