
{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A single message in a chat conversation.",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["user", "model"],
          "description": "The speaker's role."
        },
        "content": {
          "type": "string",
          "description": "The text content of the message."
        },
        "type": {
          "type": "string",
          "enum": ["standard", "knowledge", "quantum"],
          "description": "The type of response generated."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent."
        }
      },
      "required": ["role", "content", "timestamp"]
    },
    "QuantumTrace": {
      "title": "Quantum Trace",
      "description": "Metrics from a symbol-to-speech quantum fusion event.",
      "type": "object",
      "properties": {
        "top_state": { "type": "string" },
        "fusion_prob": { "type": "number" },
        "qubit_count": { "type": "integer" },
        "valence_arc": { "type": "number" },
        "decoherence_dip": { "type": "number" }
      }
    },
    "SystemLog": {
      "title": "System Log",
      "description": "A security or operational event log.",
      "type": "object",
      "properties": {
        "event": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "severity": { "type": "string", "enum": ["info", "warning", "critical"] }
      },
      "required": ["event", "timestamp"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "#/entities/Message",
      "description": "Individual messages within a specific chat session."
    },
    "/system_logs/{logId}": {
      "schema": "#/entities/SystemLog",
      "description": "Global system operational and security logs."
    }
  }
}
